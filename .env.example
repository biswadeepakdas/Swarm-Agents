# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/swarm
REDIS_URL=redis://localhost:6379

# ── LLM (via litellm — supports any provider) ────────────────
LLM_PROVIDER=anthropic
LLM_API_KEY=your_api_key_here
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS_PER_AGENT=8000
LLM_MAX_BUDGET_PER_PROJECT=5.00

# ── Embeddings ────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Swarm Config ──────────────────────────────────────────────
SWARM_MAX_CONCURRENCY=10
SWARM_MAX_AGENTS_PER_PROJECT=50
SWARM_TASK_RETRY_LIMIT=3
SWARM_AGENT_TIMEOUT_SECONDS=300
